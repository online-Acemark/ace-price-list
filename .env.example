# ACEMARK price-list — ERP API configuration (template)
# Copy this file to `.env` and fill in the values.

# Full ERP API URL (used directly in production / static builds)
VITE_ERP_API_URL=http://eksai12.ddns.net:8786/ek_api/googleAutomation/PriceList.ashx

# Same endpoint reached through the Vite dev proxy (keeps requests same-origin)
VITE_ERP_PROXY_PATH=/erp-api/googleAutomation/PriceList.ashx

# Origin the dev proxy forwards /erp-api to (read by vite.config.js, Node side)
ERP_API_ORIGIN=http://eksai12.ddns.net:8786

# Optional API key — leave blank if the ERP endpoint needs none.
VITE_ERP_API_KEY=
